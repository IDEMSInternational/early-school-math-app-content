    {
      "type": "toggle_bar",
      "name": "checkbox_see_i_to_n",
      "value": false,
      "parameter_list": "true_text: @local.description_i_to_n;\nfalse_text: @local.description_i_to_n;",
      "style_list": "flex:10;\n"
    },
    {
      "type": "text",
      "name": "spacer2",
      "style_list": "flex: 1;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "toggle_bar",
      "name": "checkbox_see_o_to_p",
      "value": false,
      "parameter_list": "true_text: @local.description_o_to_p;\nfalse_text: @local.description_o_to_p;",
      "style_list": "flex:10;\n"
    },
    {
      "type": "text",
      "name": "spacer2",
      "style_list": "flex: 1;"
    },
    {
      "type": "toggle_bar",
      "name": "checkbox_see_q_to_s",
      "value": false,
      "parameter_list": "true_text: @local.description_q_to_s;\nfalse_text: @local.description_q_to_s;",
      "style_list": "flex:10;\n"
    },
    {
      "type": "text",
      "name": "spacer2",
      "style_list": "flex: 1;"
    },
    {
      "type": "toggle_bar",
      "name": "checkbox_see_t_to_z",
      "value": false,
      "parameter_list": "true_text: @local.description_t_to_z;\nfalse_text: @local.description_t_to_z;",
      "style_list": "flex:10;\n"
    },
    {
      "type": "text",
      "name": "spacer2",
      "style_list": "flex: 1;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "condition": false
    },
    {
      "type": "button",
      "name": "see_all_button",
      "value": "See selected phrase intervals",
      "action_list": "click | set_local:see_all_phrases:TRUE;\nclick | emit:force_reload;",
      "parameter_list": "style: short; \ntext_align: center"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_display_group"
    },
    {
      "name": "comment_a",
      "value": "If glossary words are in fields, then only use them"
    },
    {
      "type": "begin_display_group",
      "name": "dg_glossary_block_some",
      "condition": "!@local.see_all_phrases",
      "parameter_list": "style: column;"
    },
    {
      "name": "gloss_word_1",
      "value": "@fields.glossary_word_1"
    },
    {
      "name": "gloss_word_2",
      "value": "@fields.glossary_word_2"
    },
    {
      "name": "gloss_word_3",
      "value": "@fields.glossary_word_3"
    },
    {
      "name": "gloss_word_4",
      "value": "@fields.glossary_word_4"
    },
    {
      "name": "gloss_word_5",
      "value": "@fields.glossary_word_5"
    },
    {
      "name": "gloss_word_6",
      "value": "@fields.glossary_word_6"
    },
    {
      "type": "begin_items",
      "name": "word_list",
      "value": "@data.esm_glossary",
      "parameter_list": "style: column;",
      "style_list": "margin-top: 10px;"
    },
    {
      "name": "same_phrase_1",
      "value": "@item.phrase == @local.gloss_word_1"
    },
    {
      "name": "same_phrase_2",
      "value": "@item.phrase == @local.gloss_word_2"
    },
    {
      "name": "same_phrase_3",
      "value": "@item.phrase == @local.gloss_word_3"
    },
    {
      "name": "same_phrase_4",
      "value": "@item.phrase == @local.gloss_word_4"
    },
    {
      "name": "same_phrase_5",
      "value": "@item.phrase == @local.gloss_word_5"
    },
    {
      "name": "same_phrase_6",
      "value": "@item.phrase == @local.gloss_word_6"
    },
    {
      "name": "use_entry",
      "value": "@local.same_phrase_1 || @local.same_phrase_2 || @local.same_phrase_3 || @local.same_phrase_4 || @local.same_phrase_5 || @local.same_phrase_6"
    },
    {
      "type": "begin_display_group",
      "name": "dg_glossary_entry_some",
      "condition": "@local.use_entry",
      "parameter_list": "style: column;"
    },
    {
      "type": "text",
      "name": "title_phrase",
      "value": "**@item.phrase**",
      "style_list": "margin-top: -10px; color: red;"
    },
    {
      "type": "begin_template",
      "name": "glossary_entry_creator",
      "value": "esm_glossary_entry_display",
      "style_list": "margin-top: -10px;"
    },
    {
      "name": "content_ptr",
      "value": "data.esm_glossary.@item.id"
    },
    {
      "type": "end_template"
    },
    {
      "type": "image",
      "name": "glossary_line",
      "value": "ESMIll/ESM0GlossaryDividingLine.svg",
      "condition": false,
      "style_list": "margin-top: 4px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_items"
    },
    {
      "type": "end_display_group"
    },
    {
      "name": "commont_b",
      "value": "dispaly all glossary entries"
    },
    {
      "type": "begin_display_group",
      "name": "dg_glossary_block_all",
      "condition": "@local.see_all_phrases",
      "parameter_list": "style: column;"
    },
    {
      "type": "begin_items",
      "name": "word_list",
      "value": "@data.esm_glossary",
      "parameter_list": "style: column;",
      "style_list": "margin-top: 10px;"
    },
    {
      "name": "display_a_to_z",
      "value": "@local.checkbox_see_a_to_z"
    },
    {
      "name": "in_a_to_c",
      "value": "@local.checkbox_see_a_to_c && @item.index < 4"
    },
    {
      "name": "in_d_to_h",
      "value": "@local.checkbox_see_d_to_h && @item.index > 3 && @item.index < 9"
    },
    {
      "name": "in_i_to_n",
      "value": "@local.checkbox_see_i_to_n && @item.index > 8 && @item.index < 15"
    },
    {
      "name": "in_o_to_p",
      "value": "@local.checkbox_see_o_to_p && @item.index > 14 && @item.index < 17"
    },
    {
      "name": "in_q_to_s",
      "value": "@local.checkbox_see_q_to_s && @item.index > 16 && @item.index < 20"
    },
    {
      "name": "in_t_to_z",
      "value": "@local.checkbox_see_t_to_z && @item.index > 19"
    },
    {
      "name": "display_it",
      "value": "@local.display_a_to_z || @local.in_a_to_c || @local.in_d_to_h || @local.in_i_to_n || @local.in_o_to_p || @local.in_q_to_s || @local.in_t_to_z"
    },
    {
      "type": "begin_display_group",
      "name": "dg_glossary_entry_all",
      "condition": "@local.display_it",
      "parameter_list": "style: column;"
    },
    {
      "type": "text",
      "name": "title_phrase",
      "value": "**@item.phrase**",
      "style_list": "margin-top: -4px; color: red;"
    },
    {
      "type": "begin_template",
      "name": "glossary_entry_creator",
      "value": "esm_glossary_entry_display",
      "style_list": "margin-top: -10px;"
    },
    {
      "name": "content_ptr",
      "value": "data.esm_glossary.@item.id"
    },
    {
      "type": "end_template"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_items"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "fake_group",
      "style_list": "margin-top: 10px;"
    },
    {
      "type": "image",
      "name": "glossary_line",
      "value": "ESMIll/ESM0GlossaryDividingLine.svg",
      "condition": false
    },
    {
      "type": "text",
      "name": "spacer"
    },
    {
      "type": "end_display_group"
    }
  ]
