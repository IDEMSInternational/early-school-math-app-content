      "value": false,
      "parameter_list": "true_text: @local.description_a_to_c;\nfalse_text: @local.description_a_to_c;",
      "style_list": "flex:10;\n"
    },
    {
      "type": "text",
      "name": "spacer2",
      "style_list": "flex: 1;"
    },
    {
      "type": "toggle_bar",
      "name": "checkbox_see_d_to_h",
      "value": false,
      "parameter_list": "true_text: @local.description_d_to_h;\nfalse_text: @local.description_d_to_h;",
      "style_list": "flex:10;\n"
    },
    {
      "type": "text",
      "name": "spacer2",
