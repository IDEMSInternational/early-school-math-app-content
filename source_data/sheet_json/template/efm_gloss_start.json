{
  "flow_type": "template",
  "flow_name": "efm_gloss_start",
  "status": "released",
  "rows": [
    {
      "type": "begin_display_group",
      "name": "dg_top_of_page"
    },
    {
      "type": "title",
      "name": "spacer",
      "value": "Glossary"
    },
    {
      "type": "begin_display_group",
      "name": "dg_help",
      "condition": false
    },
    {
      "type": "round_button",
      "name": "help_button",
      "action_list": "click | start_tour: esm_glossary_tour",
      "condition": false,
      "parameter_list": "icon_src: help; style:navigation"
    },
    {
      "type": "end_display_group",
      "condition": false
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "dg_all_or_some",
      "parameter_list": "style: column;"
    },
    {
      "type": "text",
      "name": "intro",
      "value": "Select interval(s) of phrases to see."
    },
    {
      "name": "phrase_count",
      "value": "@fields.glossary_words_count"
    },
    {
      "type": "set_field",
      "name": "glossary_words_count",
      "value": "@fields.glossary_words_count - @fields.glossary_words_count"
    },
    {
      "name": "see_all_phrases",
      "value": "@local.phrase_count == 0"
    },
    {
      "name": "description_a_to_z",
      "value": "A-Z (this will be very slow)"
    },
    {
      "name": "description_a_to_c",
      "value": "A-C"
    },
    {
      "name": "description_d_to_h",
      "value": "D-H"
    },
    {
      "name": "description_i_to_n",
      "value": "I-N"
    },
    {
      "name": "description_o_to_p",
      "value": "O-P"
    },
    {
      "name": "description_q_to_s",
      "value": "Q-S"
    },
    {
      "name": "description_t_to_z",
      "value": "T-Z"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "toggle_bar",
      "name": "checkbox_see_a_to_z",
      "value": false,
      "parameter_list": "true_text: @local.description_a_to_z;\nfalse_text: @local.description_a_to_z;"
    },
    {
      "type": "text",
      "name": "spacer2",
      "style_list": "flex: 1;"
    },
    {
      "type": "end_display_group"
    },
